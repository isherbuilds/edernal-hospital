# ============================================================
# 🔗 Shared
# ============================================================

# ✅ required - Public URL of the API server.
VITE_SERVER_URL="http://localhost:5000/server"

# ✅ required - Public URL of the web app.
VITE_WEB_URL="http://localhost:3000/web"

# ⚙️ optional - Host port for the local development PostgreSQL container.
# For multiple local scaffolded apps, give each app a different port.
DB_DEV_POSTGRES_PORT="5432"

# ✅ required - PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:changeme@localhost:${DB_DEV_POSTGRES_PORT}/tsu-stack"

# ✅ required for migration jobs - PostgreSQL owner/DDL connection string.
# Local development can match DATABASE_URL; production should use a distinct owner role.
DATABASE_MIGRATION_URL="postgresql://postgres:changeme@localhost:${DB_DEV_POSTGRES_PORT}/tsu-stack"

# ✅ required - Secret key for Better Auth. Generate with: vp run auth:secret
BETTER_AUTH_SECRET="replace-with-at-least-32-characters"

# ============================================================
# 🌍 Web
# ============================================================

# ⚙️ optional - Base URL for imgproxy. Leave empty to disable.
VITE_IMGPROXY_URL=""

# ⚙️ optional - imgproxy signature path segment. Defaults to "_" for unsigned imgproxy URLs.
# Use "insecure" or a precomputed signature string if your imgproxy setup requires it.
VITE_IMGPROXY_SIGNATURE="_"

# ============================================================
# 🖥️ Server
# ============================================================

# ⚙️ optional - Expose the OpenAPI /docs endpoint.
ENABLE_OPEN_API_DOCS="false"

# ============================================================
# 🔨 Build
# ============================================================

# ⚙️ optional - Git commit SHA injected at build time.
SOURCE_COMMIT=""
