{
  "name": "arogya-os-drizzle-schema-pack",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "auth:generate": "npx auth@latest generate --config ./src/lib/auth/auth.example.ts --output ./src/db/better-auth.generated.ts",
    "auth:migrate": "npx auth@latest migrate --config ./src/lib/auth/auth.example.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/api-key": "latest",
    "@better-auth/drizzle-adapter": "latest",
    "@better-auth/oauth-provider": "latest",
    "@better-auth/passkey": "latest",
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
